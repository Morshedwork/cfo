rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public health-check path used by /api/firebase-health
    match /__health__/{docId} {
      allow read: if true;
    }

    // Simple baseline: require auth for all other reads/writes
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

