rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public health-check path used by /api/firebase-health
    match /__health__/{docId} {
      allow read: if true;
    }

    // TEMPORARY: Allow all reads/writes for development
    // TODO: Restore auth requirements for production
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

